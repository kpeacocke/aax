# AAX Environment Configuration Example
# Copy this file to .env and update the values as needed
# DO NOT commit .env to version control

# ==================== Build Configuration ====================
# Docker image versions and metadata
VERSION=1.0.0
BUILD_DATE=
VCS_REF=

# ==================== Compose Configuration ====================
# Optional default profiles. Leave empty to avoid unintentionally enabling
# extra stacks when also passing --profile on the CLI.
# Note: services without a profiles section still start by default.
# In this repo, ee-base, ee-builder, and dev-tools are unprofiled services.
# Examples:
#   COMPOSE_PROFILES=controller
#   COMPOSE_PROFILES=controller,hub,eda
COMPOSE_PROFILES=
# Optional project name override for container/network naming
COMPOSE_PROJECT_NAME=aax

# ==================== Database Configuration ====================
# PostgreSQL database settings
POSTGRES_DB=awx
POSTGRES_USER=awx

# Shared AWX database connection settings (used by awx-postgres, awx-web, and awx-task)
DATABASE_HOST=awx-postgres
DATABASE_PORT=5432
DATABASE_NAME=awx
DATABASE_USER=awx
DATABASE_PASSWORD=REPLACE_WITH_STRONG_AWX_DATABASE_PASSWORD

# ==================== Redis Configuration ====================
# Redis cache server settings
REDIS_HOST=awx-redis
REDIS_PORT=6379

# ==================== AWX Configuration ====================
# AWX admin credentials (change these in production!)
AWX_ADMIN_USER=admin
AWX_ADMIN_PASSWORD=REPLACE_WITH_STRONG_AWX_ADMIN_PASSWORD

# AWX image (defaults to the official upstream image)
AWX_IMAGE=quay.io/ansible/awx:24.6.1

# AWX secret key for encrypting sensitive data (generate a random string)
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_SECRET_KEY

# Comma-separated hosts allowed by AWX Django settings.
# Synology DSM reverse proxy example:
#   ALLOWED_HOSTS=awx.example.com,hub.example.com,localhost,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated origins allowed for CSRF checks.
# Synology DSM reverse proxy example:
#   AWX_CSRF_TRUSTED_ORIGINS=https://awx.example.com,https://hub.example.com
AWX_CSRF_TRUSTED_ORIGINS=http://localhost:18080,http://localhost,http://127.0.0.1:18080,http://localhost:18088,http://127.0.0.1:18088

# Explicit local-dev cookie override (keep false in shared/prod environments)
AWX_ALLOW_INSECURE_COOKIES=false

# Explicit local-dev placeholder secret override (keep false outside disposable labs)
AAX_ALLOW_PLACEHOLDER_SECRETS=false

# Deprecated: replaced by AWX_ALLOW_INSECURE_COOKIES
# AWX_SESSION_COOKIE_SECURE=true
# AWX_CSRF_COOKIE_SECURE=true

# Skip database migrations on startup
AWX_SKIP_MIGRATIONS=false

# ==================== Execution Environment ====================
# Default execution environment image
DEFAULT_EXECUTION_ENVIRONMENT=aax/ee-base:1.0.0

# ==================== Receptor Configuration ====================
# Receptor work release setting
RECEPTOR_RELEASE_WORK=true

# ==================== Port Mappings ====================
# Host bind address for published ports.
# Keep 127.0.0.1 when Synology DSM reverse proxy runs on the same NAS.
# Only use 0.0.0.0 when the reverse proxy is on another machine.
HOST_BIND=127.0.0.1

# Host ports for accessing services
AWX_WEB_PORT=18080
AWX_RECEPTOR_PORT=18888
GATEWAY_PORT=18088

# ==================== Private Automation Hub ====================
# Hub database configuration
HUB_DB_PASSWORD=REPLACE_WITH_STRONG_HUB_DB_PASSWORD

# Hub admin credentials (change these in production!)
GALAXY_ADMIN_USERNAME=admin
GALAXY_ADMIN_EMAIL=admin@example.com
HUB_ADMIN_PASSWORD=REPLACE_WITH_STRONG_HUB_ADMIN_PASSWORD

# Galaxy NG secret key for encrypting sensitive data (generate a random string)
GALAXY_SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_GALAXY_SECRET_KEY

# Galaxy NG allowed hosts (comma-separated).
# Synology DSM reverse proxy example:
#   GALAXY_ALLOWED_HOSTS=hub.example.com,galaxy-ng,gateway,localhost,127.0.0.1
GALAXY_ALLOWED_HOSTS=localhost,127.0.0.1,galaxy-ng,gateway

# Content approval workflow
GALAXY_REQUIRE_CONTENT_APPROVAL=true
GALAXY_AUTO_SIGN_COLLECTIONS=false

# Collection signing (requires GPG setup)
GALAXY_SIGNATURE_UPLOAD_ENABLED=false
GALAXY_COLLECTION_SIGNING_SERVICE=
GALAXY_CONTAINER_SIGNING_SERVICE=

# Pulp secret key for encrypting sensitive data (REQUIRED - generate a random string)
# This should NOT be committed to version control or exposed in default compose files.
# Generate with: openssl rand -base64 32
PULP_SECRET_KEY=CHANGE_ME_PULP_SECRET_KEY

# Pulp allowed hosts (comma-separated).
# Application/settings default (when PULP_ALLOWED_HOSTS is unset):
#   localhost,127.0.0.1,[::1]
# Docker Compose default used in this repo (for internal service-to-service traffic):
#   localhost,127.0.0.1,[::1],pulp-api,pulp-content
# For remote access, add your hostname/IP.
# Synology DSM reverse proxy example:
#   PULP_ALLOWED_HOSTS=awx.example.com,hub.example.com,localhost,127.0.0.1,[::1],pulp-api,pulp-content,galaxy-ng,gateway
PULP_ALLOWED_HOSTS=localhost,127.0.0.1,[::1]

# Pulp content origin and API hostname
# Use an externally reachable origin so generated content URLs work for host clients.
# Synology DSM reverse proxy example:
#   PULP_CONTENT_ORIGIN=https://awx.example.com
#   PULP_ANSIBLE_API_HOSTNAME=https://hub.example.com
PULP_CONTENT_ORIGIN=http://localhost:18088
PULP_ANSIBLE_API_HOSTNAME=http://galaxy-ng:8000

# Hub port mappings
GALAXY_PORT=15001

# Pulp worker count
PULP_WORKERS=2

# Logging level
PULP_LOGGING_LEVEL=INFO
DJANGO_DEBUG=false

# ==================== Synology DSM Reverse Proxy Example ====================
# Use DSM Control Panel -> Login Portal -> Reverse Proxy to publish only HTTPS.
# Recommended external URLs:
#   https://awx.example.com -> http://127.0.0.1:${GATEWAY_PORT}
#   https://hub.example.com -> http://127.0.0.1:${GALAXY_PORT}
# Keep the defaults above for local-only access, or replace them with values
# like the example below when you are ready for remote access:
#
# HOST_BIND=127.0.0.1
# ALLOWED_HOSTS=awx.example.com,hub.example.com,localhost,127.0.0.1
# AWX_CSRF_TRUSTED_ORIGINS=https://awx.example.com,https://hub.example.com
# GALAXY_ALLOWED_HOSTS=hub.example.com,galaxy-ng,gateway,localhost,127.0.0.1
# PULP_ALLOWED_HOSTS=awx.example.com,hub.example.com,localhost,127.0.0.1,[::1],pulp-api,pulp-content,galaxy-ng,gateway
# PULP_CONTENT_ORIGIN=https://awx.example.com
# PULP_ANSIBLE_API_HOSTNAME=https://hub.example.com

# ==================== Event-Driven Ansible (EDA) ====================
EDA_DB_NAME=eda
EDA_DB_USER=eda
EDA_DB_PASSWORD=REPLACE_WITH_STRONG_EDA_DB_PASSWORD
EDA_PORT=15000
EDA_LOG_LEVEL=INFO
EDA_SKIP_DB_WAIT=false
